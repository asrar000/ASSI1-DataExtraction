# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

# Virtual environment
.venv/

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]

# Distribution / packaging
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# Environment and credentials
# ------------------------------------------------------------

# Local environment variable overrides — never commit secrets
.env

# ------------------------------------------------------------
# Runtime output — generated by the scripts at runtime
# ------------------------------------------------------------

# Extracted product data files
data/json/*
!data/json/.gitkeep

# Log files
logs/*
!logs/.gitkeep

# ------------------------------------------------------------
# OS and editor noise
# ------------------------------------------------------------

# macOS
.DS_Store

# Windows
Thumbs.db

# VS Code
.vscode/

# PyCharm
.idea/