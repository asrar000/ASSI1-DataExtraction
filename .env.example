# .env.example
#
# This file is committed to version control.
# It documents every environment variable the project uses.
#
# To get started:
#   1. Copy this file to .env
#          cp .env.example .env
#   2. Fill in the values marked as REQUIRED
#   3. Adjust any optional values if needed
#
# The .env file is loaded automatically when you run the scripts.
# Never commit .env — it contains real credentials and is already in .gitignore.


# ---------------------------------------------------------------------------
# DummyJSON API
# ---------------------------------------------------------------------------

# Base URL of the DummyJSON host — no need to change this for standard use
DUMMYJSON_HOST=https://dummyjson.com

# API key for DummyJSON — only required if using a secured/private instance
# DUMMYJSON_API_KEY=


# ---------------------------------------------------------------------------
# Mockaroo API
# ---------------------------------------------------------------------------

# Base URL of the Mockaroo host — no need to change this for standard use
MOCKAROO_HOST=https://api.mockaroo.com

# REQUIRED — Your Mockaroo API key
# Get it from: https://mockaroo.com → My Account → API Key
MOCKAROO_API_KEY=

# REQUIRED — The key of the Mockaroo schema to generate data from
# Find it in your Mockaroo account on the schema detail page
MOCKAROO_SCHEMA_KEY=