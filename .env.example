# .env.example
#
# This file is committed to version control.
# It documents every environment variable the project uses.
#
# To get started:
#   1. Copy this file to .env
#          cp .env.example .env
#   2. Fill in the values marked as REQUIRED
#   3. Adjust any optional values if needed
#
# The .env file is loaded automatically when you run the scripts.
# Never commit .env — it contains real credentials and is already in .gitignore.


# ---------------------------------------------------------------------------
# DummyJSON API
# ---------------------------------------------------------------------------

# Base URL of the DummyJSON host — no need to change this for standard use
DUMMYJSON_HOST=https://dummyjson.com

# API key for DummyJSON — only required if using a secured/private instance
# DUMMYJSON_API_KEY=


# ---------------------------------------------------------------------------
# Mockaroo API
# ---------------------------------------------------------------------------

# Base URL of the Mockaroo host — no need to change this for standard use
MOCKAROO_HOST=https://api.mockaroo.com

# REQUIRED — Your Mockaroo API key
# Get it from: https://mockaroo.com → My Account → API Key
MOCKAROO_API_KEY=

# REQUIRED — The key of the Mockaroo schema to generate data from
# Find it in your Mockaroo account on the schema detail page
MOCKAROO_SCHEMA_KEY=


# ---------------------------------------------------------------------------
# Extraction parameters
# ---------------------------------------------------------------------------

# Total number of products to extract from DummyJSON
DUMMYJSON_TOTAL_PRODUCTS=194

# Number of records per DummyJSON API call (pagination page size)
DUMMYJSON_CHUNK_SIZE=10

# Total number of records to extract from Mockaroo.
# Free tier allows 200 rows per day across all requests.
# Default is 10 (one request) to stay well within the daily limit.
MOCKAROO_TOTAL_RECORDS=10

# Number of records per Mockaroo API call.
# Keep this equal to MOCKAROO_TOTAL_RECORDS to use a single request.
MOCKAROO_CHUNK_SIZE=10

# Maximum number of retries per request on failure or HTTP 429
RETRY_LIMIT=5

# Async script only: maximum number of concurrent requests across both sources
CONCURRENCY_LIMIT=5


# ---------------------------------------------------------------------------
# Retry / backoff settings
# ---------------------------------------------------------------------------

# Exponential backoff base — wait time grows as BASE ^ attempt number (seconds)
RETRY_BACKOFF_BASE=2.0

# Maximum wait ceiling — no single retry wait will exceed this (seconds)
RETRY_BACKOFF_MAX=60.0